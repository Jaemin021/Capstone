# Copy this file to .env in this same folder before running the backend.
# Never commit the real .env file because it contains private keys.

# Required by LLM-related routes and by app startup imports.
OPENAI_API_KEY=your_openai_api_key_here

# Chat model used for item validation and survey evaluation prompts.
OPENAI_MODEL=gpt-4.1-mini

# Embedding model used for construct/semantic similarity evaluation.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Comma-separated frontend origins allowed to call this API from the browser.
# Add your frontend dev server URL here if it uses a different port.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
